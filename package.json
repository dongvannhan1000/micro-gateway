{
  "name": "micro-security-gateway",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "setup:test": "node scripts/test-setup.js",
    "dev:gateway": "npm run dev --workspace=@ms-gateway/api",
    "dev:dashboard": "npm run dev --workspace=@ms-gateway/dashboard",
    "deploy:gateway": "npm run deploy --workspace=@ms-gateway/api",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:dashboard\"",
    "test": "npm test --workspace=@ms-gateway/api"
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
