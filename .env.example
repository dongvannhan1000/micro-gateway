# Micro-Security Gateway Environment Variables
# Copy this file to .dev.vars for local development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Encryption Secret (auto-generated by setup script)
# Generate manually: openssl rand -base64 32
ENCRYPTION_SECRET=

# Optional: Email Notifications (Resend)
RESEND_API_KEY=your-resend-api-key

# Environment
ENVIRONMENT=development

# Sentry Error Monitoring (Optional - User's own Sentry account)
# Get your DSN from https://sentry.io/
# NOTE: This is for YOUR own Sentry instance, not the project maintainer's
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
